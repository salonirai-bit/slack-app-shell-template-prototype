{
  "name": "slack-vision-partner-cloud",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:clean": "rm -rf .next && NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "next build",
    "build:local": "BASE_PATH= next build",
    "build:pages": "next build && rm -rf docs && cp -r out docs && touch docs/.nojekyll",
    "preview:local": "npx --yes serve@14 out -l 3000",
    "start": "next start",
    "lint": "next lint",
    "heroku-postbuild": "echo \"Build: $(date -u +%Y%m%d%H%M%S)\" > public/build-id.txt && npm run build"
  },
  "dependencies": {
    "@auth/core": "0.36.0",
    "@convex-dev/auth": "^0.0.74",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "convex": "^1.17.0",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.12.0",
    "framer-motion": "^12.34.2",
    "jotai": "^2.10.3",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "next-themes": "^0.4.3",
    "nuqs": "^2.2.3",
    "quill": "^2.0.3",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.3.0",
    "react-resizable-panels": "^2.1.7",
    "react-use": "^17.5.1",
    "react-verification-input": "^4.2.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
